labelFunc0638_0009:
	UI_play_sound_effect2(0x005E, item);
	UI_book_mode(item);
	var0000 = UI_get_item_quality(item);
	UI_play_sound_effect2(0x005E, item);
	UI_book_mode(item);
	if (!(var0000 == 0x0078)) goto labelFunc0638_00D1;
	message("船長航海日誌*");
	say();
	message("第24天：   仍在尋找吝嗇鬼的寶藏。");
	say();
	message("\t\t\t   一整天風和日麗。船員們和以往一樣興奮。");
	say();
	message("\t\t\t   掠奪了一艘過路船，取得了一些金子和美酒。");
	say();
	message("\t\t\t   戰鬥中損失了一名船員。");
	say();
	message("第31天：   天氣非常惡劣，夜間更甚。");
	say();
	message("\t\t\t   無任何遭遇。");
	say();
	message("第32天：   平靜無事，只是修復昨夜風暴造成的損壞。");
	say();
	message("第40天：\t這個藏身處可真不好找。船員們開始坐立不安。");
	say();
	message("第41天：\t冰塊佔據了整個地平線！氣溫已經驟降。");
	say();
	message("\t\t\t\t我們快凍僵了。船員們說在這個季節從未見過");
	say();
	message("\t\t\t\t如此天氣。");
	say();
	message("\t\t\t\t燒掉越來越多的油脂取暖。我們的補給正在");
	say();
	message("\t\t\t\t迅速耗盡。");
	say();
	message("第45天：   奇怪的是冰使一切都被放大了。");
	say();
	message("\t\t\t\t陰沉的天空壓在我們頭上。憑著海盜的一句話，我們將");
	say();
	message("\t\t\t\t如利劍刺穿柔軟的腹部一般穿越這片荒蕪！");
	say();
	message("\t\t\t\t一天的死寂。");
	say();
	message("第54天：\t不得不將兩名從廚師那裡偷食物的船員處以絞刑。");
	say();
	message("\t\t\t\t惡劣的天氣加上我們對吝嗇鬼藏身處的搜索屢屢失敗，");
	say();
	message("\t\t\t\t造成了難以忍受的氣氛。");
	say();
	message("\t\t\t\t冰雪包圍著我們，感覺就像被囚禁在");
	say();
	message("\t\t\t\t這個地方。");
	say();
	message("第55天：\t昨夜我們遭遇風暴。兩名船員被發現凍死在");
	say();
	message("\t\t\t\t後甲板上。一名船員失蹤。他很可能在那個寒冷、漆黑如墨的夜裡，");
	say();
	message("\t\t\t\t因為濃密潮濕的大霧而墜海。");
	say();
	message("\t\t\t\t這次尋寶行動耗費了我們太多的人命，而且可能");
	say();
	message("\t\t\t\t還要耗費更多……");
	say();
	message("第56天：\t我們被冰流夾住了。食物快要見底。");
	say();
	message("\t\t\t\t四周全是冰封的大地，船隻動彈不得。");
	say();
	message("\t\t\t\t我們也是。");
	say();
	message("第57天\t\t為了口糧爭吵不休。");
	say();
	message("\t\t\t\t我們只剩最後一份口糧了。我們不過是幾個");
	say();
	message("\t\t\t\t裹著破爛衣物的倖存者。海上惡霸，哈！");
	say();
	message("\t\t\t\t如今我們連老鼠都嚇不倒。");
	say();
	message("第58天：   在過去的二十四小時裡，我們一直在彼此");
	say();
	message("\t\t\t\t了結對方。真是浪費！如今只剩");
	say();
	message(" \t\t\t我們兩個，還有一份口糧，僅僅一份口糧。");
	say();
	message("\t\t\t\t但我絕不屈服！");
	say();
labelFunc0638_00D1:
	if (!(var0000 == 0x0079)) goto labelFunc0638_019B;
	message("日誌~~*");
	say();
	message("第17天 -- 所有人都對我們真的抵達了北方邊疆欣喜若狂，包括我自己。");
	say();
	message("\t\t\t\t我期待著安營紮寨，找到寶藏！*");
	say();
	message("第22天 -- 我們被迫殺死了營地附近的一對狼。");
	say();
	message("第28天 -- 船員們為沒有找到任何金子而沮喪……");
	say();
	message("\t\t\t\t不過，我對我們的事業仍然充滿信心。*");
	say();
	message("第40天 -- 找到的狼比金子還多。");
	say();
	message("第41天 -- 金子。終於！");
	say();
	message("第45天 -- 婦孺都在撿金塊。");
	say();
	message("\t\t\t\t令人振奮！太棒了！");
	say();
	message("\t\t\t\t終於有了回報。*");
	say();
	message("第69天 -- 又有更多人被活生生吞噬。");
	say();
	message("\t\t\t\t狼。更多的狼。");
	say();
	message("\t\t\t\t人像狼一樣行事。比狼還壞。");
	say();
	message("\t\t\t\t他們覬覦我們的金子。");
	say();
	message("\t\t\t\t對他們來說，生命突然變得一文不值。");
	say();
	message("\t\t\t\t他們怎麼能把一塊金礦石看得比其");
	say();
	message("\t\t\t\t真正的價值更重要？*");
	say();
	message("第108天 -- 誰也不能信任。");
	say();
	message("\t\t\t\t下一個目標是誰？");
	say();
	message("\t\t\t\t希望我能活下去，我的金子不會");
	say();
	message("\t\t\t\t被偷。*");
	say();
	message("第121天 -- Hamlin 遭遇了可怕的事。");
	say();
	message("\t\t\t\t他被發現喉嚨被割開，而且，");
	say();
	message("\t\t\t\t他的金子當然不翼而飛了。");
	say();
	message("\t\t\t\t就是這一文不值的金子，他費盡辛苦積攢下來，卻");
	say();
	message("\t\t\t\t奪去了他的性命。");
	say();
	message("\t\t\t\t所以，事情已經走到這一步……");
	say();
	message("\t\t\t\t嗜金如命、嗜血如命的混蛋。*");
	say();
	message("第127天 -- 我終於找到了一條金礦脈，從中");
	say();
	message("\t\t\t\t用我的鶴嘴鋤取出了");
	say();
	message("\t\t\t\t一小量的金子。*");
	say();
	message("第148-149天 --  我整夜躺在我的床鋪上直到破曉，就是無法入睡。");
	say();
	message("\t\t\t\t太多憤怒的念頭攪擾著我的心靈。");
	say();
	message("\t\t\t\t天亮時，我在一種筋疲力盡的狀態下起身。*");
	say();
	message("第167天 -- 更多的人在內鬥。");
	say();
	message("\t\t\t\t我是如此疲憊。");
	say();
	message("\t\t\t\t這是我想要的嗎？");
	say();
	message("\t\t\t\t營地分裂成了幾派。");
	say();
	message("\t\t\t\t現在，我要停筆了，去靠著火");
	say();
	message("\t\t\t   堆休息，為");
	say();
	message("\t\t\t\t明天積蓄體力。*");
	say();
	message("第183天 -- Draygan 背叛了我們。誰能想到呢？");
	say();
	message("\t\t\t\t 我苦澀地想著他的背叛。");
	say();
	message("\t\t\t\t 船燒掉了。我們完了。");
	say();
	message("\t\t\t\t 嚎叫聲越來越近……");
	say();
labelFunc0638_019B:
	if (!(var0000 == 0x007A)) goto labelFunc0638_01B1;
	message("HAZARD 的帳本");
	say();
	message("~~毛皮~按客戶銷售~以幣表示*");
	say();
	message("……夏季~~Glendor，3 張毛皮 - 90~~Miri，1 張毛皮 - 50~~Tranch，6 張毛皮 - 180~~Falco，3 張毛皮 - 90*秋季~~蒙利多城的 Cellia，4 張毛皮 - 88~~幼鹿城的 Voldin，2 張毛皮 - 90~~ *初冬~~月影城的 Tornaldo，3 張毛皮 - 1035~~幼鹿城的 Yelinda，4 張毛皮 - 138~~幼鹿城的 Jorvin，1 張毛皮 - 34 *嚴寒~~蒙利多城的 Marsten，4 張毛皮 - 88~~蒙利多城的 Brendann，2 張毛皮 - 69~~月影城的 Fedabiblio，1 張毛皮 - 34 *隆冬~~蒙利多城的 Cellia，2 張毛皮 - 63~~月影城的 Torrissio，4 張毛皮 - 140*初春~~蒙利多城的 Cellia，1 張毛皮 - 35 *暮春~~蒙利多城的 Karl，1 張毛皮 - 25~~幼鹿城的 Garth，2 張毛皮 - 79~~Marnok，1 張毛皮 - 35");
	say();
labelFunc0638_01B1:
	if (!(var0000 == 0x007B)) goto labelFunc0638_020B;
	message("~~ ~~ ~~Briggio 的驚奇事物之書");
	say();
	message("~~一冊整理自魔法與世俗的趣味事物~~作者 月影城的 Briggio*");
	say();
	message("     在這冊為便於查閱而編撰的書中，收錄了我在研究中發現的許多迷人構造。這些物品的範圍從日常用品的趣味用途，到令人著迷的魔法奇特現象。*");
	say();
	message("法杖：三種可怕武器。~");
	say();
	message("     已知的三種魔法法杖似乎都是專門為了將戰鬥能力弱的施法者變成一台隨時備戰的魔導人偶而製造的。而且，對於那些有能力讓它們保持魔力的人來說（這絕非小事，但對任何能夠製造法杖的人而言都輕而易舉），它們或許是同等體積中最強大的武器。~~");
	say();
	message("火焰法杖：此法杖釋放出一道燃燒的死亡閃電。根據所有已知的相關文本，其殺傷力被稱為「驚人的」。~");
	say();
	message("閃電法杖：閃電從法杖中迸發出來的效果與其同類火焰法杖一樣具有毀滅性。然而，根據一位支持者的說法：「屍體看起來和聞起來要舒服多了。」~");
	say();
	message("魔法師法杖：雖然其殺傷力僅略勝於普通弓箭，但此法杖因兩個有趣的特點而相當有效：其傷害具有強烈的魔法性質，對於偏好挑戰法師的怪物尤其強力；而且，它永遠不會停止運作。如果你追求威力和持久性，這款法杖就是為你而設。*");
	say();
	message("火焰末日法杖：殺傷力本身。~");
	say();
	message("這根法杖能夠投擲真正追蹤目標的爆炸火球，或許是人-石像鬼合作時代所創造的最致命魔法武器。但是，如同大多數強力魔法武器一樣，其有限的使用壽命意味著它可能在最糟糕的時候讓你失望。*");
	say();
	message("玻璃劍：死亡的歷史遺產。~");
	say();
	message("這些一次性劍幾乎總能一擊斃命，但它們很少能用於對付第二個敵人。*");
	say();
	message("其他雜項魔法武器。~");
	say();
	message("一般來說，任何具有一點點魔法天賦的人都能通過脈動光芒來辨識魔法武器、盔甲和其他器具。然而，通常顏色能透露出比僅僅是魔法存在更多的信息。例如，綠色光場通常代表一件毒化武器。~~");
	say();
	message("爆裂箭：一支有無數目標的箭。~");
	say();
	message("這種箭的功能與普通箭相同，但在撞擊時，會爆炸成一千片飛舞的死亡碎片。~~");
	say();
	message("毒液匕首：刺客的工具。~");
	say();
	message("這把閃著綠光的匕首實際上是一顆毒海蛇的牙齒被施法後嵌入普通匕首的刀柄中。其塗毒刀刃會向受害者注入慢性毒素，但它頻繁斷裂。它是完美的暗殺武器（見 Alagner 歷史，第四世 Johann 男爵暗殺事件（第54頁））。*");
	say();
	message("石像鷹身女妖：不自然的野獸。~");
	say();
	message("石像鷹身女妖是魔法師那扭曲思想的產物。據說它是由任何生物的近距離接近魔法觸發的。");
	say();
labelFunc0638_020B:
