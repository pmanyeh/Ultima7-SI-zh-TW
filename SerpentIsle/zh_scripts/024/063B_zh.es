#game "serpentisle"
void Func063B object#(0x63B) ()
{
	var var0000;
	var var0001;

	if (!(event != 0x0001)) goto labelFunc063B_0009;
	return;
labelFunc063B_0009:
	UI_play_sound_effect2(0x005E, item);
	UI_book_mode(item);
	var0000 = UI_get_item_quality(item);
	UI_play_sound_effect2(0x005E, item);
	UI_book_mode(item);
	if (!(var0000 == 0x00B6)) goto labelFunc063B_004D;
	message("~痛覺觀察~~ 法師領主 Filbercio( MageLord Filbercio ) 著*");
	say();
	message("一、 導言");
	say();
	message("~~     我們一直將「痛苦」視為生物的神經系統對某些環境刺激的不愉快反應。但通過我最近的研究，我相信我已經開始將痛苦理解為一種心靈狀態，而不再僅僅是簡單的生理反應。");
	say();
	message("     對某人施加肉體上的痛苦是非常容易的。隨便看看我的實驗室就能證明這點。鐵處女、夾指器與拉伸刑架都對此非常有用。但對於一個字面意義上能接受甚至無視肉體痛苦的人，該怎麼辦呢？在這種情況下，對其精神能力的考驗將是必要的。仔細研究你的目標，並發現什麼能撕裂他的靈魂。理解他的心理，並利用你所發現的東西來幫助加強肉體上的折磨。");
	say();
	message("     我們現在來看幾個例子。假設你想讓一個大鍵琴演奏家感到痛苦。夾指器是顯而易見的選擇，但為什麼不在他的體驗中加入演奏那首歡快的曲子「海洋棚屋( Sea Shanty )」呢？這應該會產生非常好的效果。同樣地，如果目標是個作家，把他綁在「拉伸刑架」上，並對他朗讀那本沉悶的「鱒魚爵士的劇情指南( Sir Trout's Plot Guide )」，一定會讓他痛苦地掙扎。");
	say();
	message("     在這些書頁中，你將會發現更多產生痛苦的陰險方法。好好閱讀它們，你永遠不會對結果感到失望。");
	say();
labelFunc063B_004D:
	if (!(var0000 == 0x00B8)) goto labelFunc063B_0077;
	message("~浪漫魯特琴詩集~~ D. Dey 爵士( Sir D. Dey ) 著*");
	say();
	message("「獨白」~~~");
	say();
	message("我給了我的愛人一隻雞，");
	say();
	message("   這隻雞沒有骨頭。");
	say();
	message("我給了我的愛人一顆櫻桃，");
	say();
	message("   這顆櫻桃沒有果核。");
	say();
	message("我給了我的愛人一個故事，");
	say();
	message("   這個故事沒有結尾……");
	say();
labelFunc063B_0077:
	if (!(var0000 == 0x00C9)) goto labelFunc063B_0121;
	message("~~ ~~ 筆記~~ ~~Erstam 著*");
	say();
	message("第一個十年：");
	say();
	message("這對我來說是一個全新的時代。這片新發現的土地真是不可思議！");
	say();
	message("偉大的命運正在等待著我們的子民和你，Erstam！");
	say();
	message("這片土地有太多值得學習的地方，我心中無比喜悅。這裡的動植物有那麼多值得研究，我必須清早就開始工作。");
	say();
	message("今晚毫無睡意。我必須出去探險，去會會那些黑夜中的生物。");
	say();
	message("第三個十年的第二年：");
	say();
	message("昨晚我決定去探索這座城市的地下墓穴。我進去得快，出來得也快。這可不適合我這個年紀的人。那裡充滿了目前我還未知的生物。我的大腦想不出該如何描述牠們。我能想到的最好描述，就是說牠們是某種半人半鼠的怪物。*");
	say();
	message("第四個十年的第一年：");
	say();
	message("我仍然對這片土地上野生動物的多樣性和豐富程度感到驚奇。");
	say();
	message("你對大自然的掌控一開始總是脆弱的，Erstam，還記得嗎？");
	say();
	message("我經常會遇到怪物或是不明物種。");
	say();
	message("親愛的讀者，我仍清晰地記得，我今晚遇到的一隻奇怪的貓。");
	say();
	message("這太不可思議了。那隻貓像魔法般發著光。我因為擔心自己的生命而匆忙離去。那樣的貓一定對我們有某種奇特的影響。我想知道是哪個瘋狂的傢伙創造了這種危險。");
	say();
	message("第五個十年的第三年：");
	say();
	message("在離這不遠的地方發現了一些遺跡。");
	say();
	message("有趣地發現了一塊顎骨和巨大的尖牙。是古代文化的遺物嗎？*");
	say();
	message("第七個十年的第四年：");
	say();
	message("今天，我遇到了一個來自冰天雪地的奇怪白髮生物；牠似乎是人與野獸的雜交種。");
	say();
	message("找到了蛇神教徒( Ophidians )如何不用穿越空間就能在各處移形換位的線索。答案就在虛空之中！");
	say();
	message("第八個十年的第二年：");
	say();
	message("那是目前為止最令人恐懼的時刻。親愛的讀者，你不會相信我的，但請讓我向你保證這故事的真實性。我正在城東北邊緣的森林裡漫步，突然聽到一聲震耳欲聾的咆哮。我當場嚇得動彈不得。一隻可怕的掠食者直挺挺地站在我的正前方，身高遠遠超過了我。牠那巨大的爪子和鋒利的牙齒讓我可憐的老脊梁陣陣發涼。在寫下這些字時，我想起牠來依然在顫抖。");
	say();
	message("那隻野獸朝我的背包撲來，將它撕得粉碎，並吞食了我為這次郊遊準備的所有蜂蜜罐。*");
	say();
	message("第八個十年的第六年：");
	say();
	message("那些嫉妒我的法師偷走了我的某些秘密和力量。");
	say();
	message("牠們想要那些牙齒( Teeth )，我對此確信無疑！我必須搬到某個島上住，讓他們找不到我……");
	say();
	message("第九個十年的第三年：");
	say();
	message("我通宵工作，研究了幾個配方。");
	say();
	message("黎明已至。多麼寒冷荒涼的早晨。");
	say();
	message("需要往火堆裡再添些柴火了。");
	say();
	message("第九個十年的第四年：");
	say();
	message("今天，冰冷的狂風從冰封之地以外刮來。");
	say();
	message("如果這種情況持續下去，我將不得不做更多的乾肉。");
	say();
	message("食物所剩無幾。需要更多的柴火。");
	say();
	message("第九個十年的第六年：");
	say();
	message("這一天過得相當快，平安無事。");
	say();
	message("第九個十年的第八年：");
	say();
	message("多麼美麗的日出！");
	say();
	message("我幾乎能聞到海面上帶來的鹹鹹海風。");
	say();
	message("多麼令人心曠神怡！");
	say();
labelFunc063B_0121:
	if (!(var0000 == 0x00D1)) goto labelFunc063B_01EB;
	message("~~ ~~戰術與戰備武器簡論*");
	say();
	message("~前言~");
	say();
	message("\t~忠實且親愛的冒險者，我向你致以問候，並感謝你閱讀這篇簡短的論述。在此，為了你出發時的利益，將為你描述戰鬥戰術，最親愛的冒險者。");
	say();
	message("你將學習如何閱讀一本書，以及如何在我們的世界中聰明地戰鬥。");
	say();
	message("\t你的安全是至關重要的，因為世界足夠遼闊，你可以自由自在地漫遊。焦躁的戰士，我知道你經常縱橫交錯於土地和沼澤之間，所以想想對於棲息在這些領域的生物來說，一個受傷的人會是多麼容易被捕食的獵物。");
	say();
	message("~\t在戰鬥和未知領土中，安全的基本規則是不要認為自己強大無比。你也許在言談中顯得風趣而機敏，但你必須對你的戰鬥環境更加警惕和敏銳。適應你的對手、天氣和地形。*");
	say();
	message(" \t知己知彼。你應當知道自己的極限。你應當盡快辨認出你正面對的是哪種生物，以便你能使用最合適的策略。");
	say();
	message("\t例如，要明白草食性生物通常會逃跑。");
	say();
	message("另一方面，肉食性生物會攻擊最弱的對手。");
	say();
	message("某些生物會隨機攻擊，或者攻擊隊伍中最弱的成員。");
	say();
	message("你應當預料到民兵和守衛會使用戰術上精確的策略。最弱的成員將受到攻擊，他們會使用側翼包抄，以及戰術撤退等等……*");
	say();
	message("\t\t務必運用邏輯。例如，來自冰封之地的生物更容易受到火的傷害，而沼澤生物對毒素免疫。");
	say();
	message("攻擊敵人時，有一個現成的極佳策略：你總是可以在隱蔽後射擊。或者你可以側翼包抄並非常好地保護自己。側翼包抄時，最好使用遠程裝備，例如重弩。確保負責側翼的盟友不會傷害到你隊伍中的其他成員。強烈建議保持警惕。");
	say();
	message("\t\t善用你的戰備武器。弓總是需要箭矢。確保你不會缺乏彈藥或揮舞著無用的武器。");
	say();
	message("\t\t利用周圍環境來減緩對手的速度。例如，你可以在敵人的路徑上撒下三角釘。");
	say();
	message("\t\t最重要的是，在你的旅行隊伍中，始終保持遠程和近戰戰備武器之間的良好平衡。*");
	say();
	message("\t\t當離開城鎮去荒野冒險時，一定要順道拜訪各家商店購買背包，並在裡面裝滿各種食物。長時間旅行而不進食會讓你虛弱，更容易在敵人的攻擊中受傷。你不應繞過訓練館。你應當刻苦訓練以成為一名更好的戰士。拜訪導師並向他們學習。那些與大師們一起訓練的時間可能會挽救你的生命。*");
	say();
	message("\t\t雖然有必要明智地使用護甲，但我建議你儘快購買護甲。在購買時，請考慮以下品質：重量、堅固度、保護力。");
	say();
	message("護甲可以分為以下兩種主要類型：");
	say();
	message("\t- 古式護甲");
	say();
	message("\t- 魔法護甲");
	say();
	message("魔法護甲在保護你方面的效果幾乎是古式護甲的兩倍。");
	say();
	message("古式護甲包括皮革甲、金屬鱗甲、鎖子甲和金屬板甲。材料越堅固，保護力越強。");
	say();
	message("皮甲、皮靴、護喉、手套和皮盔提供的保護最少。但另一方面，它們也是最輕的。");
	say();
	message("鱗甲和鎖子甲、鏈甲帽與鎖子甲護腿比皮革好一點，但也沒有好太多。*");
	say();
	message("盾牌：在此類別中，小圓盾或木盾提供的保護最少。黃銅盾或弧形熨斗盾提供的保護最多。所謂保護，你應當理解為會使攻擊者的力道從你身上偏轉開來。");
	say();
	message("在頭盔中，你的選擇很大，而最好的保護來自魔法盔。不過，大頭盔幾乎同樣有效。羽飾盔和卡德萊特盔提供相同的安全程度。");
	say();
	message("鎖子甲、鏈甲帽和鎖子甲護腿對敵人打擊力道的減緩非常有限。 ");
	say();
	message("你需要一個護喉和一些護脛來保護那些暴露的致命區域。護腰帶可能有用，但我必須警告你，它提供的保護微乎其微。");
	say();
	message("板甲為你的金錢提供了堅實的保護。我也會推薦一雙金屬板甲護腿。");
	say();
	message("目前為止，在護甲方面，終極的防護如下：一個魔法盔、一個魔法盾、一個魔法護喉、一雙魔法護腿和一些魔法手套。*");
	say();
	message("\t\t親愛的戰士，為了方便起見，我將武器分為幾組。這樣一來，你只需看一眼就能輕易記住牠們的效率。我將從傷害最小的武器開始：");
	say();
	message("\t吹箭、迴力鏢、匕首、彈弓、乾草叉、鶴嘴鋤和皮鞭幾乎沒有效果。");
	say();
	message(" 魔法斧、鐵頭槌、晨星錘、雙手斧、長矛、鐵鏟或長劍對你的對手效果有限。");
	say();
	message(" 大鐮刀、普通弓、火焰劍、火槍或雙手錘的傷害稍大一些。");
	say();
	message(" 重弩（我的最愛）、長戟、閃電鞭、魔法弓、火焰法杖和火弩箭是非常強大的武器。");
	say();
	message("尋找你能獲得的最佳武器和護甲。");
	say();
	message("記住所有武器都應該保持在準備好隨時使用的狀態。");
	say();
	message("還有一句智慧之言：");
	say();
	message("不要忽視你的睡眠時間。經常睡覺會給戰士帶來所需的休息。八小時的睡眠將為你和你的盟友恢復全部精力。*");
	say();
	message("\t如果你有弱小盟友，你應該知道最合適且最有效的戰鬥方法是促使他們攻擊最弱的敵人，或者鼓勵他們逃跑。為了保護虛弱的盟友，你應當在他們身上施加保護光環。除此之外，你可以讓隊伍中最強壯的成員負責保護最弱的成員。");
	say();
	message("\t攻擊敵人時，有一個現成的極佳策略：你總是可以在隱蔽後射擊。或者你可以側翼包抄並非常好地保護自己。側翼包抄時，最好使用遠程裝備，例如重弩。確保你隊伍中負責側翼的成員不會傷害到你的其他盟友。強烈建議保持警惕。");
	say();
	message("\t你的隊友中裝備重型武器的人應該迅速攻擊最強壯的對手。其他成員應該遵循你的指導，攻擊最弱的敵人。");
	say();
	message("\t\t閱讀一本書時，尋找有用的信息並記住它或記下來，因為你以後可能會用到它。快速閱讀，但要讀完所有頁面。我再怎麼強調讀完一本書所有頁面的重要性都不為過。*");
	say();
	message("結論");
	say();
	message("~\t最親愛的冒險者，我懇求你徹底考慮上述的警告與建議。");
	say();
	message("我寫這樣一篇論述的目的是為了磨練你的戰鬥技巧，但你可以知道這本身並不是目的。");
	say();
	message("我揮舞羽毛筆的真正目的，是為了用我所有的心意和我的全部專業知識，說服你在任務完成且對冒險的渴望得到滿足後，安全地趕快回家。");
	say();
labelFunc063B_01EB:
	if (!(var0000 == 0x00D3)) goto labelFunc063B_01FD;
	message("~~ ~~沉睡士兵~~ ~~登記簿*");
	say();
	message("    ~ ~Gwenno~ ~蒙利多城的 Alinda~ ~賢者巴特林( Batlin the Sage )~ ~Draygan~~蒙利多城的 Peter");
	say();
labelFunc063B_01FD:
	if (!(var0000 == 0x00D4)) goto labelFunc063B_021B;
	message("~~ ~~酷刑論~~由白龍王皇家僕從 Evad 撰寫*");
	say();
	message("    我有幸記錄國王在瘋狂中的肆虐。作為回報，我將會被快速處死。陛下從一個名為 Patric 的平民開始，將他拉伸在刑架上。陛下親自動手，在十二個小時的過程中將這個人折磨成了一個胡言亂語的可憐蟲。");
	say();
	message("   ……在把一戶農民家庭的肉煮爛剝離骨頭後，陛下受到了啟發。他在大宴會上將一位貴賓束縛在折磨台上，並對他的四肢施加了絞索。一肢接一肢，他的四肢變成了毫無用處的死肉。陛下在僅僅五個小時後，通過在他身上割開許多小傷口，讓他流血致死，從而對受害者顯示了仁慈。*");
	say();
	message("白龍王殺死了他自己的妻子，方法是宰殺了一頭公牛，切開屍體，並將牢牢綁住的她放入切口中。然後他縫合了切口，使其除了她的頭部外什麼也沒有露出來。");
	say();
	message("他坐在外面看著屍體在她周圍腐爛，禿鷹和其他食腐獸撕碎那些肉——公牛的肉和她的肉……");
	say();
labelFunc063B_021B:
	if (!(var0000 == 0x00D5)) goto labelFunc063B_0245;
	message("~~ ~~經濟學原理~~ ~~Hyle 著*");
	say();
	message("    簡單來說，經濟學是研究一個實體如何最有效地分配其有限資源的學問。我使用「實體」這個詞，是因為這些原理在經過適度調整後，可以應用在不同的層面上。*");
	say();
	message("    從最大、因而也是最粗略的層面——即最強調貿易和專業分工之複雜性的全球市場，到個體企業的層面，或是更小的，個人努力從其生計提供的有限資金中獲得最大效用的掙扎。");
	say();
	message("    讓我們首先定義一些簡單的、潛在的理論，這些理論可能會支配我們目標的行為，而在本書中，這些理論將側重於整個經濟。我打算稍後再發表一份單獨的文件，討論完全不同層面的企業和/或個人層面的經濟基本原理。*");
	say();
	message("    正如在任何科學中一樣，人們首先必須獲得一個建立其知識的基礎；在這個特定的例子中，我將稱之為「經濟理解之塔」。*");
	say();
	message("    市場是我研究的基礎。市場並非有形之物——不像人們為了需要或想要而與商人交易的集市（這些我將在本書中進一步定義），儘管集市是市場的一部分。");
	say();
	message("    相反，市場由消費者（購買資源的實體）和銷售者（提供資源用於出售或貿易的實體）組成。例如，在上述集市上，提供一條麵包的麵包師是銷售者，而有興趣購買該麵包的實體是消費者。*");
	say();
	message("    當有資源需要交換時，市場就存在了。資源在最簡單的術語中，可以是商品或服務。商品是有形物品——例子包括水、鑽石和假鬍鬚。服務是由實體履行的某事；例如，貨船提供的服務，甚至是政府機構如常備守備隊的士兵……");
	say();
labelFunc063B_0245:
	if (!(var0000 == 0x00D6)) goto labelFunc063B_025F;
	message("~~ ~~巨蛇之島居民~~  ~~Byman 著*");
	say();
	message("    四分之一世紀（二百五十年）前，人魔不列顛王( Lord British )向索沙利亞( Sosaria )的公民灌輸了他的八大美德。大多數公民被矇騙，相信了他的生活方式是公正公平的。一些人足夠強大，反對他的統治並逃離，去建立他們自己的文明，擺脫壓迫性的專制統治。*");
	say();
	message("    這些勇敢的人在一位勇敢的法師帶領下（遺憾的是他的勇敢現在已被遺忘），冒險出海，幾乎不知道他們的終點在哪裡；只堅信不列顛王是一個不能容忍的暴君。Erstam 帶領他們來到一個大島，該島立即被命名為「新索沙利亞( New Sosaria )」。不久之後，因為在那裡發現了奇特的遺跡，這片土地的名字被改為「巨蛇之島」。*");
	say();
	message("    離開索沙利亞的有三個主要群體——月之法師( Mages of Moon )、雙蒙特城( Two Montors )的騎士們，以及港口城市幼鹿城( Fawn )的居民。每個人都有自己加入移民的理由：法師們是因為他們覺得不列顛王的某些美德是不切實際的；幼鹿城人是因為不列顛王未能承認第九完美德——美貌；而蒙利多城( Monitor )的勇敢人民則是因為他們相信勇氣高於一切……");
	say();
labelFunc063B_025F:
	if (!(var0000 == 0x00D7)) goto labelFunc063B_0281;
	message("~~ ~~英勇事跡~~ ~~蒙利多城的 Andrew 著*");
	say();
	message("~~ 第一章~~  ~~Kosric 與 Pedigar 的傳奇*");
	say();
	message("\tKosric 與 Pedigar 兄弟隨最初的探險隊航行到了巨蛇之島，當時這片土地比今天更未知和神秘。兩兄弟分別是索沙利亞( Sosaria )上雙蒙特城( Two Montors )中其中一座的領主，他們不滿足於不列顛王不妥協且誤導的統治，說服了他們的子民與月之法師和幼鹿城的子民一起乘船前往新大陸。*");
	say();
	message("\t然而，在另外兩座城市的歷史書中遺失的，是這群疲憊的旅人首次踏上這片新土地時發生的故事。領袖是一位名叫 Erstam 的法師（他肯定不可能是今天進行無法容忍實驗的那個瘋子 Erstam），他榮幸地第一個踏上了巨蛇之島。接著由各個群體的領袖決定誰將下一個踏上這座未知之島。Kosric 與 Pedigar 聲稱擁有這個權利，因為他們的群體是他們當中最優秀的戰士。幼鹿城人也聲稱擁有這個權利，爭辯說他們的美麗應該在其他人之前與新島嶼的美麗融合。月影城( Moonshade )的法師們因為不值得信任，在另外兩個群體進行討論時，用傳送術將自己傳送到了島上，竊取了這個榮譽。*");
	say();
	message("\t最大的榮譽已經失去，幼鹿城人和蒙利多城人一起走下了舷梯。月之法師在受到譴責之前就像風一樣散開了，幼鹿城人則跑去探索島嶼的美麗。就在那一刻，從山丘和林地中湧出的巨魔( trolls )開始對這群勇敢的人發起襲擊。如果不是 Kosric 和 Pedigar 以及他們的蒙利多戰士，探險隊在當時當地就會失敗，因為幼鹿城人和月之法師都猝不及防。然而，這兩兄弟衝向了敵人，Kosric 揮舞著他的戰錘「霹靂( Thunderbolt )」，Pedigar 揮舞著他的大劍，給那些可惡的巨魔帶來了毀滅。*");
	say();
	message("\t戰鬥結束後，二十名勇敢的蒙利多戰士倒在兩倍於此數量的巨魔屍體旁。不要忘記，勇敢的蒙利多子民，正是你的祖先為這個島上所有文明生活開闢了道路。");
	say();
labelFunc063B_0281:
	if (!(var0000 == 0x00D8)) goto labelFunc063B_0297;
	message("~~ ~~食譜書~~ ~~Petra 著*");
	say();
	message("蘋果派做法~ ~ 2個蘋果，去皮切片~ 1杯糖~ 2湯匙玉米澱粉~ 2湯匙奶油~ 1茶匙肉桂粉~ 1個雙層派皮*");
	say();
	message("將蘋果、糖、玉米澱粉和肉桂粉放入一個大碗中混合。將混合物放入底層派皮中，放入奶油。鋪上頂層派皮，並切出切口以便蒸汽排出。在350度的烤箱中烘烤約45分鐘。");
	say();
labelFunc063B_0297:
	if (!(var0000 == 0x00D9)) goto labelFunc063B_02BD;
	message("~~ ~~食譜書~~ ~~Petra 著*");
	say();
	message("甜麥芬~ ~ 3/4杯牛奶~ 1/2杯糖~ 2茶匙鹽~ 1/2杯奶油~ 1/2杯溫水~ 5盎司酵母~ 1個雞蛋~ 4杯未過篩的麵粉~*");
	say();
	message("將牛奶加熱，拌入糖、鹽和奶油。冷卻至微溫。在大溫碗中量取溫水。加入酵母並攪拌至溶解。拌入微溫的牛奶混合物、雞蛋和一半的麵粉，攪拌至光滑。拌入剩餘的麵粉，調成濃稠的麵糊。用蠟紙將碗口封緊。將麵團冷藏至少兩個小時。*");
	say();
	message("將麵團分成兩半，將每塊滾成9乘14英吋的矩形。刷上一層薄薄的融化奶油。");
	say();
	message("內餡：~ 在矩形上撒上 3/4 杯糖、1 茶匙肉桂粉以及 1/3 杯葡萄乾和山核桃的混合物。將矩形捲成9英吋長（像果醬捲一樣）。確保邊緣封口牢固。*");
	say();
	message("將每個捲切成九等份，並放入抹了油的烤盤中（留出足夠的空間供麵團膨脹）。蓋上烤盤，讓麵團在溫暖的地方發酵，直到捲的體積增加一倍。在中溫（華氏350度）下烘烤約30分鐘。*");
	say();
	message("糖霜：~ 用糖粉（1 1/2杯）和5茶匙牛奶的混合物塗抹表面。");
	say();
labelFunc063B_02BD:
	if (!(var0000 == 0x00DD)) goto labelFunc063B_02D7;
	message("~~ ~~戰鬥是一門藝術~~ ~~Johnson 著*");
	say();
	message("~  第一課： ~   在戰鬥中，無論你必須做什麼，你都絕對不能輸。任何與你戰鬥的人都是敵人。敵人必須被消滅。 ~\t在戰鬥中，你將面對你的敵人。你必須擊敗他，否則你會給自己、你的氏族和你的導師帶來恥辱。 ~    戰鬥總是在地平線上浮現。你必須刻苦訓練，嚴格要求自己。如果你期望獲得勝利，你必須在思考戰鬥、飲食戰鬥、睡眠戰鬥中度過。那些認為自己做不到這點的戰士應該考慮換個工作。");
	say();
	message("~   了解你的武器是最重要的價值。無論是劍、鐵頭槌還是弓，你都必須跟它一起訓練直到精通，如果你想成為一名真正的戰士。如果你沒有時間或心思進行這種方式的訓練，那麼你也許應該改去訓練使用鐵鏟，以及把農田裡的動物排泄物運走。盡你所能為你的氏族服務，即使那是一個不配稱為騎士的職位，也比你在戰鬥中逃跑並危及你的戰友要好。");
	say();
	message("\t 任何被抓到從戰鬥中逃跑的人都應該立即被處以劍刑，免得其他人覺得他們可以讓娘娘腔的恐懼佔據上風。真正的騎士不是那些打仗的人，而是那些樂於灑血的人。那些迷戀被切開的肚子，或看到別人的血染紅他的劍和護甲而著迷的人，應該受到高於一切的讚美。這就是一個真正的騎士所追求的。他是戰鬥藝術的真正大師。");
	say();
labelFunc063B_02D7:
	if (!(var0000 == 0x00DE)) goto labelFunc063B_0311;
	message("~~ ~~不列顛王的暴政冒險記~~ ~~佚名 著 *");
	say();
	message("~不列顛王是一位傲慢虛榮的君王， ~尤其為他專制的統治感到無比張狂。 ~但這種自負根本就不合適， ~很快這位老暴君就注定要面臨墜落。 ~一天，當他從高處俯瞰他的臣民時， ~一個豐滿的年輕少婦吸引了他疲憊的老眼。*");
	say();
	message("~那隻色迷迷的老山羊彎腰去看， ~讓他的金王冠滑落並掉進了護城河中。 ~伴隨著一聲純粹恐怖的尖叫，他像個傻瓜一樣跳了起來， ~他沖向了他的溝渠（那裡臭得像個化糞池）。*");
	say();
	message("~他撲通一聲跳了進去！像石頭一樣沉了下去。 ~（每個人都希望能有新的王位繼承人。） ~但唉，他浮了上來，步履蹣跚地走出了下水道， ~他的長袍聞起來像內臟，他的呼吸像肥料。*");
	say();
	message("~「我為什麼要那樣做？今天是什麼附了我的身？ ~我像老 Iolo 一樣愚蠢，現在我聞起來像 Dupre。」 ~「而且如果有人看見我，哦，多麼丟臉， ~如果我想留點面子，我最好離開！」");
	say();
	message("~但人群已經聚集並驚訝地注視著， ~眼前的景象讓他們困惑，惡臭讓他們眩暈。 ~然後伴隨著一聲尖叫，一個小男孩開始大笑， ~咯咯笑著並指著國王的糞便浴。*");
	say();
	message("~君王變得暴怒，突然變得瘋狂， ~他看起來想掐死那個孩子！ ~他的手變成了拳頭，他以閃電般的速度擊去， ~但這個老傻瓜沒打中，屁股摔在了地上。");
	say();
	message("~人群不再克制，很快爆發出雷鳴般的笑聲， ~笑聲震耳欲聾。笑聲越來越大。 ~但國王覺得這不好笑，並召集了他的部下。 ~衛兵的到來迅速壓制了嘈雜聲。*");
	say();
	message("~「對於你們所有人在我的悲傷和不幸中尋找樂趣的人， ~很快就會迎來拉伸刑架！還有痛苦！還有扭曲！ ~然後我會在你燉煮和沸騰時咯咯笑， ~在一個裝滿豬油和冒泡油的鍋裡。*");
	say();
	message("~而對於那些活下來的人（他們寧願死掉）， ~我會挖出他們的眼睛，砍掉他們的頭！ ~最後他們的屍體將在風中搖擺， ~然後你們這些傻瓜會後悔嘲笑這位國王！」*");
	say();
	message("~然後所有人都被用劍指著帶走了， ~而老不列顛王在一處淺灘洗了個澡。 ~然後他在尖叫聲中大笑，那聲音在夜空裡迴盪， ~他看著他們的痛苦而呵呵笑，看著他們的困境而咯咯笑。*");
	say();
	message("~在今天的不列顛尼亞，沒有人公開講述這個故事， ~免得他們發現自己被扔進暴君最黑暗的監獄裡。 ~但在我們的新家園，這首歌可以唱出來， ~關於不列顛王如何沾染上他淡淡糞便味的故事。");
	say();
labelFunc063B_0311:
	if (!(var0000 == 0x00DF)) goto labelFunc063B_0327;
	message("~~ ~~哭泣的魯特琴 ~~ ~~Gannt 著*");
	say();
	message("~當我輕輕撥動手中的魯特琴時， ~它在哭泣，因為它知道我已變成了多麼空虛的人， ~知道我的悲劇、我的悲傷、我孤獨的絕望。 ~只有我的魯特琴在傾聽，獨自一人，只有它在乎。 ~ ~雖然我是一名騎士， ~隱藏著我的情感， ~我依然能感受到內心吞噬靈魂的黑暗。 ~我是一個身披鎧甲、手握利劍的人， ~但我感到的黑暗卻無法抵擋。*");
	say();
	message("~綠色的野豬來了，進行著沉默懦弱的襲擊， ~帶著弓與箭，帶著劍與斧。 ~牠們為了我們的鮮血而來，為了吃我們的肉體， ~我們將牠們砍死，我們的刃片剝下牠們的肉。 ~ ~雖然我曾愛過她，她依然離開了人世， ~她蒼白的皮膚被哥布林的血腥刀刃刺穿。 ~但我卻被留在這裡，只是一個空虛的人形軀殼。 ~我無法言語，悲傷超出了我所能承受。 ~ ~其他人飲酒自醉，我卻無法參與 ~其他人都在歡慶，但我無法裝出笑容。 ~我會坐在火堆旁輕輕撥動琴弦， ~只有我的魯特琴知道我最終變成了多麼空虛的人。");
	say();
labelFunc063B_0327:
	if (!(var0000 == 0x00E0)) goto labelFunc063B_0341;
	message("~~ ~~獨角獸之家 ~~ ~~Gannt 著*");
	say();
	message("~來吧！進入獨角獸富饒的屋子。 ~敞開你的耳朵和心靈， ~吸收這匹戰馬美麗尖角上的魔力！ ~我們現在不是， ~也從未是過 ~獨角獸的子民。 ~但如果我們屈服於自己， ~並聆聽精靈的音樂 ~很快有一天我們將與獨角獸同在。*");
	say();
	message("~在你出生的那天 ~為我們的地球帶來了一道新的陽光 ~提供溫暖和綠色的財富 ~驅走女巫的巫術。 ~我們都分享了收穫月亮的恩賜， ~並投身於魯特琴和旋律之中 ~並飲下清晨露水的財富 ~品味珍貴的少數被選中者所擁有的樂趣。*");
	say();
	message("~哦，屬於被獨角獸選中的人， ~心靈的財富，沒有對孤獨的恐懼。 ~我們可以在草地上隨著呢喃的奇蹟起舞， ~並乘著閃電前行，指揮雷霆。 ~哦，偉大的戰馬，你這魔法野獸， ~為了向你致敬，我們分麵包並設宴。 ~我們在暮光的最後虛無中高舉酒杯 ~我們在獨角獸之家，我們將永遠居住在那裡。");
	say();
labelFunc063B_0341:
	if (!(var0000 == 0x00E1)) goto labelFunc063B_0357;
	message("~~ ~~世上本無仙子 ~~ ~~Gannt 著*");
	say();
	message("~在我們的童年歲月裡，我們了解到仙子會發光， ~這很好，每個人都知道。 ~但我們飲用了黑暗漿果的汁液 ~儘管我們知道世上本無仙子…… ~ ~我們哭泣，雖然我們很少表現出來， ~我們的淚水像融化的山雪般落下。 ~但仙子依然像煙圈般在夜空中飄浮。 ~用牠們神話般的魔力視線矇騙我們。*");
	say();
	message("~伴隨着奪取無價珍寶的幸運， ~以及隨之而來的月影城( Moonshade )樂趣 ~隨着我們長大、變得更大膽並被吸引， ~仙子拜訪我們的次數越來越少，直到，唉，牠們消失了。 ~ ~但對於我們的子孫，仙子依然會發光， ~這很好，每個孩子都知道。 ~但我們繼續飲用黑暗漿果的汁液 ~因為我們知道世上本無仙子……");
	say();
labelFunc063B_0357:
	if (!(var0000 == 0x00E2)) goto labelFunc063B_0381;
	message("~~ ~~DEVRA 的食譜~~ ~~*");
	say();
	message("青椒洋蔥炒雞肉~ ~ 2杯米飯~ 1 1/2杯粗切的青椒~ 3/4杯薄切洋蔥~ 3湯匙沙拉油~ 1/4杯玉米澱粉~ 2杯雞湯~ 3湯匙醬油~ 2杯切碎的熟雞肉~ 3個熟透的番茄，切成薄片~ ~ 在油中炒青椒和洋蔥至嫩。混合玉米澱粉和少許雞湯。加入剩餘的雞湯和醬油。輕輕將雞肉和湯拌入蔬菜中。煮並攪拌直到醬汁變澄清並變稠。加入番茄並煮至熱。澆在米飯上盛盤。六人份。*");
	say();
	message("起司西蘭花砂鍋~ ~ 1/2條奶油~ 1杯米飯，煮熟~ 1杯切碎的洋蔥~ 1束西蘭花，切碎~ 6盎司蘑菇濃湯~ 4盎司融化的起司~ ~ 在平底鍋中融化奶油；加入切碎的洋蔥並炒至澄清。加入切碎的西蘭花。徹底攪拌。加入蘑菇濃湯。攪拌並慢火煮幾分鐘。加入1杯煮熟的米飯；攪拌並慢火煮。如果太稠，加入少量水並在350度下煮25至30分鐘。*");
	say();
	message("蘋果堅果方塊~ ~ 3個雞蛋~ 1 3/4杯糖~ 1杯食用油~ 2茶匙香草精~ 2杯麵粉~ 1茶匙鹽~ 1茶匙小蘇打~ 1 1/2茶匙肉桂粉~ 2杯去皮切丁的蘋果~ 1/2杯切碎的胡桃~ ~ 將烤箱加熱到325度。在9乘13英吋的烤盤上抹上一層薄薄的油。在大攪拌碗中混合前8種原料；快速攪拌3分鐘（約150下）。拌入蘋果和胡桃。倒入準備好的烤盤中。烘烤50至60分鐘，直到插入中心的牙籤拔出時是乾淨的。配上打發鮮奶油、冰淇淋，或直接撒上糖粉食用。可供12至15人食用。*");
	say();
	message("下午茶塔西餅~ ~ 3盎司奶油起司~ 1/2杯奶油~ 1杯過篩的麵粉~ 3/4杯紅糖~ 1湯匙軟化奶油~ 1茶匙香草精~ 1個雞蛋~ 少許鹽~ 2/3杯碎杏仁或其他堅果~ ~ 混合奶油起司和奶油。拌入麵粉。冷藏1小時。塑造成2打1英吋的球。在小杯子或麥芬模具的底部和側面壓出皮。將除了堅果以外的剩餘原料一起打發。將一半的堅果分配到杯中。將雞蛋混合物倒在堅果上。在325度下烘烤25分鐘。*");
	say();
	message("美味熱狗~ ~ 1磅熱狗香腸~ 2湯匙奶油~ 10 3/4盎司番茄湯~ 1/4杯紅糖~ 1/4杯水~ 3湯匙醋~ 1湯匙伍斯特醬~ 1/2個檸檬，切薄片~ 1/2個洋蔥，切薄片~ 1/4杯切碎的青椒~ ~ ~ 將香腸以螺旋方式劃開。在平底鍋中，用奶油將香腸輕輕煎至棕色。加入除青椒以外的剩餘原料。蓋上蓋子慢火煮10分鐘。加入青椒並再煮5分鐘。*");
	say();
	message("花生醬法奇軟糖~ ~ 2杯糖~ 少許鹽~ 2/3杯牛奶~ 1湯匙清糖漿~ 2湯匙奶油~ 1杯花生醬~ 1茶匙香草精~ ~ ~ 混合前4種配料並煮至軟球階段。加入剩餘配料並混合。迅速倒入抹了油的盤中並切成方塊。*");
	say();
	message("手工麵條~ ~ ~ 1個雞蛋，打散~ 1茶匙軟化奶油~ 1/2茶匙鹽~ 2湯匙牛奶~ 1茶匙蘋果醋~ 1杯麵粉~ ~ ~ 混合雞蛋、奶油、鹽、牛奶和醋。加入足夠的麵粉以做成硬麵團。在撒了麵粉的表面上擀得非常薄。讓麵團靜置約2小時，直到乾燥。切成條狀。將麵條放入鹽水或高湯中。煮10分鐘。可做成3杯未煮熟的麵條。");
	say();
labelFunc063B_0381:
	if (!(var0000 == 0x00E3)) goto labelFunc063B_0397;
	message("~~ ~~驚奇鱒魚食譜~~ ~~Jendon 著*");
	say();
	message("香煎整條鱒魚~ ~ 鱒魚，2至3磅，清理乾淨~ 2茶匙鹽~ 1/2茶匙研磨胡椒粉~ 1/2杯黃玉米麵~ 1/2杯麵粉~ 3湯匙奶油~ 8湯匙植物油~ 1個檸檬，切成瓣~*");
	say();
	message("在冷水下清洗鱒魚；用毛巾拍乾。撒上鹽和胡椒。混合玉米麵和麵粉。在重型平底鍋中，在中溫下將奶油融化在油中。當泡沫開始消退時，將鱒魚在玉米麵/麵粉混合物中滾一下，抖掉多餘的麵粉，放入平底鍋中。每面煎4-5分鐘，直到金黃酥脆。配上檸檬瓣食用。");
	say();
labelFunc063B_0397:
	if (!(var0000 == 0x00E4)) goto labelFunc063B_03D1;
	message("~~ ~~騎士指南~~ ~~蒙利多城的 Graeme 著~~");
	say();
	message("勇氣在你的心中；如果你的心沒有面臨被利刃刺穿的危險，你就無法憑勇氣戰鬥。*");
	say();
	message("勇敢的人選擇長劍、戰錘、鐵頭槌和戰斧作為武器。警惕那些能很好地揮舞這些武器的人，因為他們是強悍的對手。~");
	say();
	message("也要警惕那些施法的人，因為他們毫無勇氣，而懦夫會編織欺騙、謊言和詭計的網。");
	say();
	message("勇氣表現在戰場上，勇氣最大的一方，無論人數多少，都將獲得勝利。~");
	say();
	message("一個勇敢的人知道，離開戰場只有兩種方式：消滅所有的敵人，或者死亡。");
	say();
	message("一個你救了其生命的人，或者救了你生命的人，在你的餘生中都是可以信任的。~");
	say();
	message("騎士絕不能為了個人的目標而忽視他領主的目標。~");
	say();
	message("勇氣不僅僅是拿起長劍反抗他的敵人；它也是承認並彌補自己缺點的勇氣，而如果恰好騎士錯了，他必須有勇氣承認。*");
	say();
	message("一名騎士必須知道，除了他所喜愛的武器的武藝之外，還要了解戰術藝術，因為總有一天，他的同胞騎士的生命可能會由他的戰術決定決定。~");
	say();
	message("任何背叛他人的騎士都將被永遠禁止再次拿起武器。犯下這種惡行的騎士不是騎士；他就像他曾經與之交戰的哥布林一樣。~");
	say();
	message("勇氣與愚蠢是分開的；在某些戰鬥中，有時間逃跑並重新集結，但僅限於那些無法獲勝的戰鬥。~");
	say();
labelFunc063B_03D1:
	if (!(var0000 == 0x00E5)) goto labelFunc063B_03F3;
	message("~~ ~~命運戰士季刊~~ ~~冒險者指南~~ ");
	say();
	message("\t對於你們這些意志堅定、在鋼鐵武器的道路上富有天賦的人來說，比你們夢想的更偉大的財富就在你們不遠的將來。你所要做的就是閱讀這些書頁中所包含的秘密，你將踏上致富之路。進入那些在各個時代都困擾著人們的謎團，其回報大於今天的王國。來吧，冒險和黃金就在你的地平線上。*");
	say();
	message("~本期為意志堅定的冒險者提供了一個率先找到守財奴寶藏的機會！那裡的黃金比十艘船能裝載的還要多！繼續讀下去，了解世界上最富有的失去巢穴之一的歷史和位置。你能第一個找到它嗎？ ~\t幾百年前，有一個名叫 Triphako 的守財奴，他通過欺詐當地土著以及僱用海盜襲擊競爭對手的船隻和貨物，積累了巨額財富。*");
	say();
	message("~\t一天晚上，在做了一個關於失去巨額財富的清晰夢境後，Triphako 諮詢了一位偉大的巫師。賢者預警說，守財奴即將在不久的將來失去他所有的財富，他做什麼也無法阻止這一切。守財奴以為自己可以避開預言，將他所有的黃金帶到北方冰冷地帶的一個洞穴中安全存放。他僱用巫師在洞穴後部創建了一系列通道，如果沒有魔法地圖，任何人都無法在其中找到路。 ~\t當一切完成後，巫師召喚了一隻冰龍( Ice Dragon )來守衛通往財寶的洞穴口。在返回宮殿的航程中，守財奴擔心巫師會洩露他的秘密，便將巫師推進海裡淹死了。");
	say();
	message("~\t不幸的是，在巫師死後，魔法地圖在一股藍煙中消失了。守財奴擔心預言成真，回到洞穴並試圖找到通往他財寶的路線。正如巫師警告的那樣，守財奴從未接觸到他的財富。大多數人說他躺在冰封洞穴的某個地方，因為他再也沒有回來。");
	say();
	message("~\t時至今日，還沒有人能從通道中倖存並到達冰龍的巢穴。有些人曾試圖在洞穴口面對冰龍，但所有人都逃跑了，或者成為了洞穴口周圍冰層中的永久裝飾物。 ~\t如果你足夠勇敢，並且對自己的戰鬥技能有信心，你可能會找到進入 Triphako 巢穴並獲得他無數財寶的秘密通道。");
	say();
labelFunc063B_03F3:
	if (!(var0000 == 0x00E6)) goto labelFunc063B_0415;
	message("~~ ~~火葬儀軌~~ ~~Tolbert 著~~");
	say();
	message("~\t讓這本書作為指南，引導那些跟隨我從事這項光榮職業的人，為人類所知的所有土地上最優秀的戰士——蒙利多城( Monitor )優秀的戰士們進行火葬！");
	say();
	message("\t其中大部分將在你的學徒期間為你所知，但這些文字將有助於加強你的前輩教給你的東西。~");
	say();
	message("\t你可以從你的職業中學到的最重要的事情是：成為一名火化師是一項不亞於拿起長劍和盾牌，與哥布林、巨魔以及居住在我們土地上的所有其他未開化魔鬼作戰的光榮和有價值的職責。我向任何懷疑者提出這個問題：如果一個戰士知道，如果他英勇地戰死沙場，他的屍體（或者身體）就不會被帶回來接受適當的火葬，他會怎麼樣？他那在生前為戰爭而準備和訓練的身體，應該餵養那些寧願逃跑也不願戰鬥的懦夫，或者可能成為擊倒他的那些邪惡生物妻子的美餐？他會呆在軍隊的後方，希望自己能回家；更擔心自己的生命，而不是引導他的刀刃穿過敵人的心臟。*");
	say();
	message("\t我已經向你展示了你的職業價值；現在我將向你透露燃燒一個人屍體的重要性，這與原始的土葬做法相反。從你說出第一個字的那天起，你就知道死者的骨灰中含有神秘的力量。這是真的，你從你的騎士考驗( Test of Knighthood )中知道這點。骨灰是一個人靈魂的縮影；他的精神被鎖定在他無生命的屍體遺骸中，而燃燒它則將精神從囚禁中釋放出來。如果不這樣做，精神就會發瘋，並作為一個怪物升起——無生命，卻充滿仇恨、復仇心和活力。精神處於折磨中。這不是一個勇敢的騎士度過永恆的方式。出於這樣的原因，火化師是我們堅固城市中受人尊敬和光榮的成員。~");
	say();
	message("\t問題是，在屍體被火化後（具體方法在後面的章節中詳細描述），骨灰必須存放在哪裡？我們祖先的幸運和智慧使我們置身於一片土地上，大山向西的一個開口可以作為地下墓穴；一個安葬勇敢死者的墳墓。看來這些曾經是魔鬼的土地，西北部的遺跡證明了這點，但更明確的是地下墓穴。在那裡，棺材和落滿灰塵的掛毯裝著他們未燒毀的死者。毫無疑問，那個地方只是一片廢墟，因為發瘋的屍體確實站了起來，向那些傻瓜發泄了他們的報復……");
	say();
labelFunc063B_0415:
	if (!(var0000 == 0x00E7)) goto labelFunc063B_042B;
	message("~~混沌神殿~ Miggim 譯*");
	say();
	message("~Xenka 的預言提到古代 Ophidian 的混沌神殿在某種程度上對來自異世界之英雄( Hero from Another World )很重要。雖然我未能解開 Xenka 關於這些神殿之幻象的真正含意，但我感到來自異世界之英雄肯定會需要一些關於牠們位置的信息。我已將 Chaos 神殿的簡短描述從 Ophidian 文字翻譯成了符文文字。*");
	say();
	message("情感神殿( Temple of Emotion )是從碎骨者( Skullcrusher )的活石中雕刻而成的。要尋找情感神殿，你應當尋找一個小湖。神殿的入口在該湖以南不遠處。熱忱神殿( Temple of Enthusiasm )位於海岸邊，在偉大的碎脊者( Spinebreaker )山脈以北。寬容神殿( Temple of Tolerance )建在海岸附近，位於碎脊者和碎骨者山脈之間雪谷的北端。");
	say();
labelFunc063B_042B:
	if (!(var0000 == 0x00FA)) goto labelFunc063B_0453;
	message("~~ ~~偉大的惡作劇~~  ~~*");
	say();
	message("第一章：爆炸的書 *");
	say();
	message("嘿，嘿，嘿。");
	say();
	var0001 = UI_execute_usecode_array(item, [(byte)0x23, (byte)0x55, 0x02C0]);
labelFunc063B_0453:
	return;
}


