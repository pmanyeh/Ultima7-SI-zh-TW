	if (!UI_is_pc_female()) goto labelFunc0282_04EC;
	var0001 = "她";
	var0002 = "她的";
	var0003 = "她";
	var0004 = "她";
	var0005 = "她的";
labelFunc0282_04EC:
	message("預言之書~~ 作者：Xenka*");
	say();
	message("\t\t當陌生人在你的土地上與你同住時，你不可虧待他或她。與你同住的陌生人，你要看他或她如你們中間的本地人一樣。你要愛他或她如愛自己；因為我看到了來自另一個世界的英雄降臨，他將統整巨蛇並拯救世界。*");
	say();
	message("我看到岩石在移動，樹木裂開——我看到隱藏了幾個世紀的寶藏出現。在那裡我看到了三個當中的一個。它是黑色的。它是魔法的。");
	say();
	message("\t\t我清楚地看到了一位來自另一個世界的英雄，但必須說");
	message(var0003);
	message("並不是獨自一人。");
	message(var0004);
	message("絕不能獨自前進！我祈求你首要記住這點。");
	message(var0004);
	message("必須有三個同伴相隨。*");
	say();
	message("\t\t來自另一個世界的英雄將透過使用強大的魔法、幽靈的協助以及大祭司的三件法器而獲得成功。*");
	say();
	message("\t\t我的話照亮了黑暗。跟隨我的話語展開，你將看到英雄的朋友將會是");
	message(var0002);
	message("的敵人。幻象將使");
	message(var0001);
	message("比");
	message(var0002);
	message("的敵人更有智慧，因為");
	message(var0001);
	message("總是如此。");
	say();
	message("來自另一個世界的英雄甚至必須在");
	message(var0002);
	message("的夢中取得勝利。*");
	say();
	message("死者將會幫助");
	message(var0001);
	message("，但生者之中的敵人將會比比皆是。");
	say();
	message("必須謹慎選擇盟友以確保成功。來自另一個世界的英雄甚至需要一個小偷和一個吹牛大王作為");
	message(var0002);
	message("的盟友。");
	say();
	message("我如同隔著面紗看著未來——");
	message(var0003);
	message("將會與那些曾經是");
	message(var0002);
	message("的敵人結盟，並將在壞人中找到好人。我看到了紅色，還有一個女人牽涉其中。");
	say();
labelFunc0282_055C:
	if (!(var0000 == 0x004F)) goto labelFunc0282_057E;
	message("第8天——這個爛地方不適合我。在這裡似乎不可能狂歡。");
	say();
	message("第9天——為巴特林做了一些工作。他太自以為是了。我希望他掉下懸崖。");
	say();
	message("第12天——我當初為什麼要離開不列顛尼亞？");
	say();
	message("第20天——巴特林最好用黃金付我錢，不然我會給他");
	say();
	message("一個教訓。");
	say();
	message("黃金是我離開這個污水坑並在不列顛尼亞找點樂子的唯一方法。已經知道我要買什麼了！Buccaneer's Den 對我來說是個好地方！");
	say();
labelFunc0282_057E:
	if (!(var0000 == 0x0050)) goto labelFunc0282_05A0;
	message("~~ ~~我的日記~~ ~~作者：Silverpate*");
	say();
	message("第9週第3天：~~今天，我又跟 Erstam 吵了一架，那個脾氣暴躁的老瘋子法師！我從來受不了他，也永遠受不了。他以為他是誰？我和 Erstam 差別太大了，我們根本無法共事。*");
	say();
	message("第9週第4天：~~我珍貴的顎骨( Jawbone )，我真高興你是我的，我一次又一次地使用你，仍然沒有理由抱怨。沒有你我該怎麼辦，告訴我？Erstam，你不是唯一一個可以穿越虛空的人！*");
	say();
	message("第9週第7天：~~你的魔法望遠鏡不過是你畏懼我的力量時想出的另一個把戲。對一個瘋狂的老法師來說是一件無用的裝備。我對你感到厭倦了。我明白為什麼 Drogeni 再也沒有回來...~");
	say();
	message("你在尋找永生，但你最後會孤單一人的，Erstam！~");
	say();
	message("我，Silverpate，將會證明你是錯的。我將發現與我們的事情相關的解決方案。");
	say();
labelFunc0282_05A0:
	if (!(var0000 == 0x0053)) goto labelFunc0282_05B6;
	message("~~ ~編織~~ ~~作者：Carlyn*");
	say();
	message("     這是一本包含各種圖案的完整資料書。其中包括衣物、毛毯、被子和床單的圖案。簡介中甚至包含了一節關於如何編織自己的布料。~");
	say();
	message("     ...拿一捆羊毛，在紡車上紡成線。完成後，將線拉在織布機上開始編織。不久你就會擁有一塊漂亮的布料，可以從中製作各種有用的東西。為了增加變化，可以在織布機上使用不同顏色的線來創造令人興奮的圖案。");
	say();
labelFunc0282_05B6:
	if (!(var0000 == 0x005A)) goto labelFunc0282_05D4;
	message("~~ ~~黑色概要~~ ~~作者：Mondain，由女巫 Minax 加上註解，以及由地獄子嗣 Exodus 提供魔法配方。*");
	say();
	message("     延長壽命是一個複雜的過程，需要數年才能完成。然而，還有一個額外的副作用：刀槍不入。我將這項工作根據每個單獨的儀式分成了幾個章節。非常重要的是，這些步驟必須按照這裡呈現的順序進行。*");
	say();
	message("     首先，你必須取得五顆粉碎紅寶石的粉末。這必須與黏怪的黏液徹底混合，足以將紅寶石變成濃稠的糊狀物。在製作好糊狀物後，將其放入象牙罐中，並將整個容器放入一桶橄欖油中存放三年。*");
	say();
	message("     下一步是取得十個新生嬰兒，且出生不超過六天。用一把從鷹身女妖骨頭上切割下來的刀，你必須取出每個新生兒的血液。為了保持新鮮，血液必須儲存在瑪瑙燒瓶中，雖然混合每個嬰兒的血液也是完全可以接受的。*");
	say();
	message("     現在你應當尋找...");
	say();
labelFunc0282_05D4:
	if (!(var0000 == 0x005B)) goto labelFunc0282_05EE;
	message("~~ ~~Brommer 的植物相~~ ~~作者：Brommer*");
	say();
	message("     這本大部頭書籍描述了不列顛尼亞的大部分常見原生植物。~~");
	say();
	message("  ...Greer 植物特別迷人，因為它一生的大部分時間都蜷縮著，葉子緊緊地包裹成一個球。然而，每隔一段時間，葉子就會展開，從莖部向外輻射...*");
	say();
	message("  ...樹精( Reaper )的獨特之處在於它既是植物也是動物。樹精外形像一棵大樹，能夠自我活動以及自我移動。眾所周知，樹精會攻擊那些對他們的家園（即森林）造成傷害的人，但在其他情況下很少現身...");
	say();
labelFunc0282_05EE:
	if (!(var0000 == 0x005C)) goto labelFunc0282_0608;
	message("~~ ~~Brommer 的動物相~~ ~~作者：Brommer*");
	say();
	message("     在這本書的封面之間，可以找到居住在不列顛尼亞土地上最常見動物的詳細資訊。~~");
	say();
	message("  ...鹿在不列顛尼亞的森林地區相當普遍。牠們是害羞的生物，通常會避開人類的出現，牠們知道人類會獵殺牠們。在牠們的頭頂上長著一對鹿角...*");
	say();
	message("  ...狐狸是一種小型動物，類似狗或狼。牠是雜食性動物，當牠厭倦了其他食物時，非常樂意將就一下農夫的雞...");
	say();
labelFunc0282_0608:
	if (!(var0000 == 0x0062)) goto labelFunc0282_061E;
	message("~~ ~~不列顛尼亞的鳥類~~ ~~作者：Wayne 修士*");
	say();
	message("     本書是一本關於鳥類的綜合指南，由許多不同的藝術家繪製了精美且色彩豐富的插圖。");
	say();
	message("     ...令許多人驚訝的是，銀翼 Pharcelot 並不是不列顛尼亞最普遍的鳥類，儘管牠可以說是最顯眼的。黑尖 Grackle 要受歡迎得多，但牠偏好黑暗涼爽的區域，使得牠相當不顯眼。");
	say();
labelFunc0282_061E:
	return;
}
